# Token simples do teu app pessoal. Use uma frase/senha grande.
APP_SECRET=troque-por-uma-senha-grande

# Em dev, o Vite roda em 5173. Em produção use a URL real do app.
CORS_ORIGIN=http://localhost:5173
PORT=3001

# Ordem de fallback. O backend tenta na ordem até algum provedor gerar o áudio.
# Exemplos:
# TTS_PROVIDER_ORDER=elevenlabs,openai
# TTS_PROVIDER_ORDER=openai,elevenlabs
TTS_PROVIDER_ORDER=elevenlabs,openai

# ElevenLabs: pode usar uma ou várias chaves separadas por vírgula.
# ELEVENLABS_VOICE_IDS acompanha a ordem das chaves; se só houver uma voz, ela será usada para todas as chaves.
ELEVENLABS_API_KEYS=coloque_key_1,coloque_key_2
ELEVENLABS_VOICE_IDS=coloque_voice_id_1,coloque_voice_id_2
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# OpenAI: pode usar uma ou várias chaves separadas por vírgula.
OPENAI_API_KEYS=sk-proj-chave_1,sk-proj-chave_2
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin

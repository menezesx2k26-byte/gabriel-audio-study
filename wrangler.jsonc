{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "coisas-para-fazer-com-a-mh",
  "main": "./src/worker.js",
  "compatibility_date": "2026-07-19",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "durable_objects": {
    "bindings": [
      { "name": "ROOMS", "class_name": "SharedList" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SharedList"] }
  ]
}

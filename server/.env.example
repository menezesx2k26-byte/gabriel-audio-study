# Nunca coloque essa chave no frontend.
OPENAI_API_KEY=sk-proj-coloque_sua_chave_aqui

# Token simples do teu app pessoal. Use uma frase/senha grande.
APP_SECRET=troque-por-uma-senha-grande

# Em dev, o Vite roda em 5173.
CORS_ORIGIN=http://localhost:5173
PORT=3001

# Modelo/voz padrão. A doc oficial recomenda marin/cedar para melhor qualidade.
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin
